        "b9d6eb19-10f4-41f8-bfdc-ea10e8b3182a": {
          "type": "custom",
          "settings": {
            "open_tab_mobile": false,
            "title": "Key Ingredients",
            "type": "all",
            "content": "<div>\n  <div>\n    <h3>AM ROUTINE</h3>\n    <p><strong>1. Cleanser:</strong> Centella Asiatica, Green Tea Extract, Glycerin</p>\n    <p><strong>2. Toner:</strong> Licorice Root Extract, Hyaluronic Acid, Madecassoside</p>\n    <p><strong>3. Serum:</strong> Niacinamide, Alpha-Arbutin, 3-O-Ethyl Ascorbic Acid</p>\n    <p><strong>4. Eye Cream:</strong> Peptide Complex, Caffeine, Ceramides</p>\n    <p><strong>5. Moisturizer:</strong> Snail Mucin Extract, Centella Asiatica, K8-Rejuvenate™</p>\n    <p><strong>6. Primer + SPF:</strong> Zinc Oxide, Titanium Dioxide, Niacinamide</p>\n  </div>\n\n  <br>\n\n  <div>\n    <h3>PM ROUTINE</h3>\n    <p><strong>1. Cleansing Oil:</strong> Camellia Oil, Jojoba Oil, Rice Bran Oil</p>\n    <p><strong>2. Cleanser:</strong> Centella Asiatica, Green Tea Extract, Glycerin</p>\n    <p><strong>3. Toner:</strong> Madecassoside, Licorice Root Extract, Hyaluronic Acid</p>\n    <p><strong>4. Serum:</strong> Niacinamide, Peptide Complex, K8-Rejuvenate™</p>\n    <p><strong>5. Eye Cream:</strong> Peptide Complex, Ceramides, Snail Mucin Extract</p>\n    <p><strong>6. Night Cream:</strong> Snail Mucin Extract, Centella Asiatica, Alpha-Arbutin</p>\n  </div>\n</div>",
            "product_custom_source": "dynamic",
            "product_tab_key_metafield": "",
            "enable_btn_show_more": false,
