          "settings": {
            "open_tab_mobile": false,
            "title": "Benefits",
            "type": "all",
            "content": "<div>\n  <p>✔ Complete 7-Step Skincare System</p>\n  <p>✔ All-in-one routine delivered in precision-measured capsules</p>\n  <p>✔ Simple, guided steps with a clear daily sequence</p>\n  <p>✔ Designed for convenience while traveling or on the go</p>\n  <p>✔ Single-use format to maintain hygiene and freshness</p>\n  <p>✔ Helps support a balanced, comfortable skin feel</p>\n  <p>✔ Formulated to work across multiple skin types</p>\n  <p>✔ Encourages regular use for more consistent outcomes</p>\n  <p>✔ Low-effort routine designed for everyday simplicity</p>\n  <p>✔ Suitable for both first-time users and skincare enthusiasts</p>\n</div>",
